# Everything runs through OpenRouter — one key powers the whole app.
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Coach model (questions, scoring, follow-ups, cheat sheet)
COACH_MODEL=google/gemma-4-26b-a4b-it

# Leave OPENROUTER_API_KEY blank and set this to "true" to make every visitor enter their own key.
REQUIRE_USER_KEY=false

# Independent "hiring manager" model — a DIFFERENT model, for a real second opinion.
# Uses the OpenRouter key/endpoint above by default; only the model differs.
JUDGE_MODEL=openai/gpt-4o-mini
# Optional overrides if you want the judge on a different key/endpoint:
# JUDGE_API_KEY=
# JUDGE_BASE_URL=

# Local speech-to-text (faster-whisper). Use "tiny" on memory-constrained hosts.
ASR_DEVICE=cpu
ASR_MODEL_SIZE=base
ASR_COMPUTE_TYPE=int8

# Set to false on memory-constrained hosts to skip librosa's numba-JIT pitch pass.
ENABLE_PITCH_ANALYSIS=true
